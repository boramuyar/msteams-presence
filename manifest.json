{
  "manifest_version": 3,
  "name": "MS Teams Presence",
  "description": "Nudges Microsoft Teams web tabs while Chrome reports the system as active.",
  "version": "0.1.0",
  "permissions": ["idle", "tabs", "alarms"],
  "host_permissions": [
    "https://teams.microsoft.com/*",
    "https://*.teams.microsoft.com/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://teams.microsoft.com/*",
        "https://*.teams.microsoft.com/*"
      ],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ]
}
